{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/blackpebble build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/blackpebble/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE-WITH-YOUR-API-HOST.onrender.com/api/:path*"
    }
  ]
}
