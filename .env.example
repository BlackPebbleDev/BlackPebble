# ============================================================================
# BlackPebble — local development environment
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored — NEVER commit real secrets.
# ============================================================================

# --- Required ---------------------------------------------------------------

# PostgreSQL connection string (local instance or hosted).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blackpebble

# API server listen port. The frontend dev server proxies /api here.
PORT=8080

# --- Auth (required in production; optional in dev) --------------------------

# Secret used to sign JWT session cookies. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# X (Twitter) OAuth 2.0 credentials. Without these, X login is disabled.
X_CLIENT_ID=
X_CLIENT_SECRET=

# Request offline.access for refresh tokens (default: enabled). Set false to skip.
# X_OAUTH_OFFLINE_ACCESS=false

# Optional OAuth 1.0a consumer keys — improves banner image fetch (v1.1 users/show).
# X_CONSUMER_KEY=
# X_CONSUMER_SECRET=

# URL the OAuth flow redirects back to (your frontend origin).
FRONTEND_URL=http://localhost:5173

# --- Solana / market data (optional, features degrade gracefully) ------------

# Server-side Helius API key (token metadata, RPC).
HELIUS_API_KEY=

# Client-side Helius key — baked into the browser bundle at build time.
# Restrict it by domain in the Helius dashboard.
VITE_HELIUS_API_KEY=

# Optional full RPC URL override for the browser wallet adapter.
VITE_HELIUS_RPC_URL=

# Birdeye API key for sparkline history (skipped when unset).
BIRDEYE_API_KEY=

# --- Admin (optional) ---------------------------------------------------------

# Comma-separated X user IDs granted admin access.
ADMIN_X_USER_IDS=

# Token protecting the destructive /api/admin/reset endpoint (503 when unset).
ADMIN_RESET_TOKEN=

# --- Production only ----------------------------------------------------------

# Comma-separated CORS allowlist, e.g. https://blackpebble.fun
CORS_ALLOWED_ORIGINS=

# Pino log level (default: debug in dev, info in prod).
LOG_LEVEL=
